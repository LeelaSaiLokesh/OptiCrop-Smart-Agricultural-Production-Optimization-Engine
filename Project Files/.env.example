# OptiCrop – Environment Variables Template
# ─────────────────────────────────────────
# Copy this file to .env and fill in the values.
# The .env file is loaded by run.py via python-dotenv.
# NEVER commit .env to version control (it is in .gitignore).

# ── Flask environment ─────────────────────────────────────────────────────────
# Options: development | production | testing
FLASK_ENV=development

# ── Secret key ────────────────────────────────────────────────────────────────
# Required in production. Must be at least 32 random characters.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=opticrop-dev-secret-CHANGE-THIS-IN-PRODUCTION

# ── ML Model paths ────────────────────────────────────────────────────────────
# Paths are relative to the project root (where run.py lives)
MODEL_PATH=models/model.pkl
ENCODER_PATH=models/encoder.pkl

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_DIR=logs
LOG_LEVEL=INFO

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000
